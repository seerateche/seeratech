# ============================================================
# SEERA PLATFORM v4 - Environment Variables
# Copy this to .env and fill in your production values
# ============================================================

# ── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sira_db
DB_USER=sira
DB_PASSWORD=sira_secure_2025
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sira_redis_2025

# ── JWT (MUST change in production! min 64 chars each) ────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_64_CHARACTERS_LONG_PLEASE_GENERATE_RANDOMLY
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MINIMUM_64_CHARACTERS_LONG_GENERATE_RANDOMLY

# ── AES-256-GCM Encryption Key ───────────────────────────
# Generate: openssl rand -hex 32
# MUST be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage ──────────────────────────────────────────────
STORAGE_PATH=/tmp/sira-streams
UPLOADS_PATH=/tmp/sira-uploads

# ── WireGuard VPN ────────────────────────────────────────
WG_SERVER_URL=auto
WG_PORT=51820
WG_PEERS=20

# ── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Super Admin Seed (first run) ─────────────────────────
SEED_SUPER_ADMIN_EMAIL=superadmin@seera.local
SEED_SUPER_ADMIN_PASSWORD=Change_Me_2025!
SEED_SUPER_ADMIN_NAME=Super Administrator
