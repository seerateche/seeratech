# ============================================================
# SEERA PLATFORM v4 - Environment Variables
# Copy this to .env and fill in your production values
# ============================================================

# ── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────
# Managed providers (Railway/Render/etc.) inject a single DATABASE_URL.
# When DATABASE_URL is set it takes precedence over the DB_* values below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sira_db
DB_USER=sira
DB_PASSWORD=RUN__openssl_rand_-hex_32__AND_PASTE_HERE
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RUN__openssl_rand_-hex_32__AND_PASTE_HERE

# ── JWT (MUST change in production! min 64 chars each) ────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=RUN__openssl_rand_-hex_32__AND_PASTE_HERE
JWT_REFRESH_SECRET=RUN__openssl_rand_-hex_32__AND_PASTE_HERE

# ── AES-256-GCM Encryption Key ───────────────────────────
# Generate: openssl rand -hex 32
# MUST be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=RUN__openssl_rand_-hex_32__AND_PASTE_HERE

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=YOUR_PRODUCTION_WEB_URL,YOUR_DEV_WEB_URL
# Debug escape hatch — allow every origin (REST + WebSocket). NEVER use in prod.
# CORS_ALLOW_ALL=false

# ── Diagnostics / Migrations (production recovery) ───────
# Required to run the on-demand table-creation endpoint and to view the
# diagnostics endpoint in production:
#   POST /api/v1/auth/run-migrations   {"secret":"<MIGRATION_SECRET>"}
#   GET  /api/v1/auth/debug?secret=<MIGRATION_SECRET>
# In production, /auth/debug refuses to answer unless this is set + matched.
MIGRATION_SECRET=RUN__openssl_rand_-hex_32__AND_PASTE_HERE

# Expose Swagger docs (/api/docs) in production. Leave unset/false normally.
# ENABLE_SWAGGER=false

# ── Storage ──────────────────────────────────────────────
STORAGE_PATH=/mnt/data/streams
UPLOADS_DIR=/mnt/data/uploads

# ── WireGuard VPN ────────────────────────────────────────
WG_SERVER_URL=auto
WG_PORT=51820
WG_PEERS=20

# ── Frontend (Vite) ──────────────────────────────────────
# Native APK / web client reads VITE_API_BASE_URL (see apps/web/src/utils/api.ts)
VITE_API_BASE_URL=http://localhost:3001

# ── Super Admin Seed (first run) ─────────────────────────
SEED_SUPER_ADMIN_EMAIL=superadmin@seera.local
SEED_SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SEED_SUPER_ADMIN_NAME=Super Administrator
