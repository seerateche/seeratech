# ============================================================
# SEERA PLATFORM v4 - Environment Variables
# Copy this to .env and fill in your production values
# ============================================================

# ── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────
# Managed providers (Railway/Render/etc.) inject a single DATABASE_URL.
# When DATABASE_URL is set it takes precedence over the DB_* values below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sira_db
DB_USER=sira
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_SSL=false

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT (MUST change in production! min 64 chars each) ────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_64_CHARACTERS_LONG_PLEASE_GENERATE_RANDOMLY
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MINIMUM_64_CHARACTERS_LONG_GENERATE_RANDOMLY

# ── AES-256-GCM Encryption Key ───────────────────────────
# Generate: openssl rand -hex 32
# MUST be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage ──────────────────────────────────────────────
STORAGE_PATH=/tmp/sira-streams
UPLOADS_PATH=/tmp/sira-uploads

# ── WireGuard VPN ────────────────────────────────────────
WG_SERVER_URL=auto
WG_PORT=51820
WG_PEERS=20

# ── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Super Admin Seed (first run) ─────────────────────────
SEED_SUPER_ADMIN_EMAIL=superadmin@seera.local
SEED_SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SEED_SUPER_ADMIN_NAME=Super Administrator
