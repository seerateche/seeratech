# ============================================================
# SEERA WEB / MOBILE - Frontend Build Environment
# Copy to .env before building: cp .env.example .env
# ============================================================

# Backend API base URL
# - Web/browser: leave EMPTY → nginx proxy handles /api → backend
# - Native APK:  REQUIRED → set to your backend's public URL
#
# Examples:
#   VITE_API_BASE_URL=https://api.seera.example.com
#   VITE_API_BASE_URL=http://192.168.1.50:3001     # LAN testing
VITE_API_BASE_URL=
