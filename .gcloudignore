# ============================================================
# Files NOT uploaded to Cloud Build (keeps uploads small & fast).
# The Docker builds run `npm install` inside the image, so local
# node_modules / build output are never needed in the build context.
# ============================================================

# IMPORTANT: Do NOT inherit .gitignore rules — we control everything here.
# Without this line, gcloud may auto-inherit .gitignore and exclude files
# that Docker needs (like package-lock.json in subdirectories).

.git
.github

# Dependencies (reinstalled inside the Docker build)
node_modules/
**/node_modules/

# Build output (rebuilt inside Docker)
dist/
**/dist/

# Local env / secrets — must NEVER reach the build
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
*.log

# Android / Capacitor native build artifacts
apps/web/android/
apps/web/ios/
android/
ios/

# Source map files (not needed in build)
*.js.map
