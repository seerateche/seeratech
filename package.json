{
  "name": "seera-platform",
  "version": "4.0.0",
  "private": true,
  "description": "Seera Platform v4 - Smart Integrated Business Solutions",
  "type": "module",
  "scripts": {
    "build": "npm run build:web && node scripts/cap-setup.mjs",
    "build:web": "cd apps/web && npx vite build",
    "build:api": "cd apps/api && npm install --legacy-peer-deps && npm run build",
    "dev": "cd apps/web && npm run dev",
    "cap:sync": "npx cap sync android",
    "postinstall": "npx cap add android || true"
  },
  "dependencies": {
    "@capacitor/android": "5.7.6",
    "@capacitor/app": "5.0.7",
    "@capacitor/core": "5.7.6",
    "@capacitor/network": "5.0.8",
    "@capacitor/splash-screen": "5.0.7",
    "@capacitor/status-bar": "5.0.7",
    "@tanstack/react-query": "^5.18.1",
    "axios": "^1.6.5",
    "hls.js": "^1.5.5",
    "lucide-react": "^0.316.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.7.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "5.7.6",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-legacy": "^5.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "core-js": "^3.36.0",
    "postcss": "^8.4.35",
    "regenerator-runtime": "^0.14.1",
    "tailwindcss": "^3.4.1",
    "terser": "^5.27.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}